alias vi=nvim

# Rails
alias mg='rails db:migrate'
alias mgs='rails db:migrate:status'
alias rb='rails db:rollback'
alias b='bundle'
alias be='bundle exec'
alias tpp='rails db:test:prepare'
alias rc='rails c -- --nomultiline'
alias rs='rails s'
alias r='rails'
alias test='bundle exec rspec --color'
alias staging='mcdo run --cluster v3-stg-clu --service v3-stg-puma-svc "bundle exec rails c -- --nomultiline"'
alias prod='mcdo run --cluster v3-prd-clu --service v3-prd-sidekiq-marketplace-svc "bundle exec rails c -- --nomultiline"'
alias air='$(go env GOPATH)/bin/air'

# Git
alias glog="git log --graph --pretty=format:'%Cred%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative"
alias lgb='git lgb'
alias wip='git add . && git commit -m "wip"'
alias piw='git reset --soft HEAD~1'
alias gs='git-spice'
alias gl="git log --graph --pretty=format:'%Cred%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative"
alias codex='codex --dangerously-bypass-approvals-and-sandbox'


bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word

alias v3config="cp ~/Documents/works/mycloud/config/database.yml ~/Documents/works/mycloud/config/application.yml ./config"
alias v4config="cp ~/Documents/works/mycloud-oms-v4/config/database.yml ~/Documents/works/mycloud-oms-v4/config/application.yml ./config"
